# Connection string de Neon (Postgres)
# La consigues en: Neon Console -> tu proyecto -> Dashboard -> "Connect" -> copia la URL
DATABASE_URL="postgresql://usuario:password@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# API key de Google Gemini (gratis)
# La consigues en: https://aistudio.google.com -> "Get API key" -> "Create API key"
GEMINI_API_KEY="AIzaSy..."

# ---- Chatbot de WhatsApp (opcional; solo si activas el bot) ----
# Token permanente de la app de Meta (System User con permisos de WhatsApp)
WHATSAPP_TOKEN=""
# ID del número de prueba (aparece en Meta -> WhatsApp -> API Setup)
WHATSAPP_PHONE_NUMBER_ID=""
# Palabra secreta que tú inventas; debe coincidir con la que pongas al configurar
# el webhook en Meta (ej: "timepath123")
WHATSAPP_VERIFY_TOKEN=""
